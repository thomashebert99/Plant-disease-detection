# ── MLflow / DagsHub ──────────────────────────────────────────────────
# En local : pointer vers le serveur DagsHub (même URI qu'en production)
MLFLOW_TRACKING_URI=https://dagshub.com/<user>/<repo>.mlflow
MLFLOW_TRACKING_USERNAME=your_dagshub_username
MLFLOW_TRACKING_PASSWORD=your_dagshub_token_here

# ── API ───────────────────────────────────────────────────────────────
CONFIDENCE_THRESHOLD=0.65
LOG_LEVEL=INFO
MODEL_SOURCE=local
ENSEMBLE_CONFIG_PATH=models/ensemble_config.json
MONITORING_STORAGE_DIR=logs
# Optionnel si vous voulez surcharger les noms de fichiers par défaut.
# MONITORING_LOG_PATH=logs/predictions.jsonl
# FEEDBACK_LOG_PATH=logs/feedback.jsonl
MONITORING_LOW_CONFIDENCE_THRESHOLD=0.65
MONITORING_MAX_ERROR_RATE=0.05
MONITORING_MAX_UNCERTAIN_RATE=0.25
MONITORING_MIN_DISEASE_CONFIDENCE=0.65
MONITORING_MAX_P95_LATENCY_MS=5000
MONITORING_DRIFT_MIN_EVENTS=5
MONITORING_DRIFT_WINDOW=50
MONITORING_FEEDBACK_MIN_EVENTS=3
MONITORING_MAX_DISAGREEMENT_RATE=0.30

# ── Hugging Face Hub (stockage des modèles) ───────────────────────────
HF_TOKEN=your_huggingface_token_here
HF_REPO_ID=your-username/plant-disease-detection-models

# ── Streamlit ─────────────────────────────────────────────────────────
API_URL=http://localhost:8000
