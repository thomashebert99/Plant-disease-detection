# ── MLflow / DagsHub ──────────────────────────────────────────────────
# En local : pointer vers le serveur DagsHub (même URI qu'en production)
MLFLOW_TRACKING_URI=https://dagshub.com/<user>/<repo>.mlflow
MLFLOW_TRACKING_USERNAME=your_dagshub_username
MLFLOW_TRACKING_PASSWORD=your_dagshub_token_here

# ── API ───────────────────────────────────────────────────────────────
CONFIDENCE_THRESHOLD=0.85
LOG_LEVEL=INFO

# ── Hugging Face Hub (stockage des modèles) ───────────────────────────
HF_TOKEN=your_huggingface_token_here
HF_REPO_ID=your-username/plant-disease-detection-models

# ── Google Cloud Run (déploiement API) ────────────────────────────────
GCP_PROJECT_ID=your_gcp_project_id
GCP_REGION=europe-west1
